generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                     @id @default(cuid())
  name                     String?
  email                    String                     @unique
  passwordHash             String
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  mailboxes                VirtualMailbox[]
  sentEmails               SentEmail[]
  leads                    Lead[]
  intakeForms              IntakeFormSubmission[]
  caseProfiles             IrccCaseProfile[]
  consultationHostProfile  ConsultationHostProfile?
  hostedConsultations      Consultation[]            @relation("ConsultationHost")

  @@index([email])
}

enum ConsultationStatus {
  PENDING
  COMPLETED
  EXPIRED
  CANCELLED
}

enum ConsultationMeetingRole {
  HOST
  GUEST
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  DOCS_REQUESTED
  SUBMITTED
  DECISION_MADE
  CLOSED
}

model VirtualMailbox {
  id                 String      @id @default(cuid())
  ownerId            String
  owner              User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  passportId         String
  emailAddress       String      @unique
  label              String?
  passwordCiphertext String
  passwordIv         String
  passwordTag        String
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  sentEmails         SentEmail[]
  inboundReads       InboundEmailRead[]

  @@unique([ownerId, passportId])
  @@index([ownerId])
  @@index([emailAddress])
}

model SentEmail {
  id                    String          @id @default(cuid())
  ownerId               String
  owner                 User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  mailboxId             String
  mailbox               VirtualMailbox  @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  resendEmailId         String?
  toAddresses           String[]
  ccAddresses           String[]
  bccAddresses          String[]
  subject               String?
  textBody              String?
  htmlBody              String?
  status                String          @default("queued")
  replyToInboundEmailId String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([ownerId, createdAt])
  @@index([mailboxId, createdAt])
}

model InboundEmail {
  id                    String                   @id @default(cuid())
  resendEmailId         String                   @unique
  webhookEventType      String
  webhookCreatedAt      DateTime?
  webhookReceivedAt     DateTime                 @default(now())
  resendCreatedAt       DateTime?

  fromRaw               String
  fromName              String?
  fromAddress           String?
  fromDomain            String?

  toAddresses           String[]
  ccAddresses           String[]
  bccAddresses          String[]
  replyToAddresses      String[]

  toRecipients          Json
  ccRecipients          Json?
  bccRecipients         Json?
  replyToRecipients     Json?

  subject               String?
  messageId             String?
  inReplyTo             String?
  references            String[]
  headers               Json?
  htmlBody              String?
  textBody              String?

  rawMessageDownloadUrl String?
  rawMessageExpiresAt   DateTime?
  attachmentCount       Int                      @default(0)

  rawWebhook            Json?
  rawReceivingEmail     Json?
  source                String                   @default("webhook")

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  attachments           InboundEmailAttachment[]
  readBy                InboundEmailRead[]

  @@index([createdAt])
  @@index([fromAddress])
  @@index([fromDomain])
  @@index([subject])
}

model InboundEmailRead {
  mailboxId             String
  mailbox               VirtualMailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  emailId               String
  email                 InboundEmail   @relation(fields: [emailId], references: [id], onDelete: Cascade)
  readAt                DateTime       @default(now())

  @@id([mailboxId, emailId])
  @@index([emailId])
  @@index([mailboxId, readAt])
}

model InboundEmailAttachment {
  id                 String       @id @default(cuid())
  emailId            String
  email              InboundEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)

  resendAttachmentId String
  filename           String?
  contentType        String?
  contentDisposition String?
  contentId          String?
  sizeBytes          Int?
  downloadUrl        String?
  downloadExpiresAt  DateTime?

  storageBucket      String?
  storagePath        String?
  storagePublicUrl   String?
  storageUploadedAt  DateTime?
  sha256             String?

  rawMetadata        Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([emailId, resendAttachmentId])
  @@index([resendAttachmentId])
  @@index([storageBucket, storagePath])
}

model Lead {
  id                 String                @id @default(cuid())
  ownerId            String
  owner              User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  fullName           String
  email              String?
  phone              String?
  passportId         String?
  visaProgram        String?
  countryOfResidence String?
  source             String                @default("manual")
  stage              LeadStage             @default(NEW)
  score              Int                   @default(0)
  notes              String?
  nextFollowUpAt     DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  formSubmissions    IntakeFormSubmission[]
  caseProfiles       IrccCaseProfile[]

  @@index([ownerId, stage, createdAt])
  @@index([email])
}

model IntakeFormSubmission {
  id                 String    @id @default(cuid())
  leadId             String?
  lead               Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  ownerId            String?
  owner              User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  source             String    @default("dashboard")
  fullName           String
  email              String
  phone              String?
  visaProgram        String?
  countryOfResidence String?
  message            String?
  consentToContact   Boolean   @default(false)
  status             String    @default("new")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([ownerId, createdAt])
  @@index([email, createdAt])
  @@index([status, createdAt])
}

model IrccCaseProfile {
  id                     String             @id @default(cuid())
  ownerId                String
  owner                  User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  leadId                 String?
  lead                   Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  label                  String
  trackerType            String             @default("manual")
  irccIdentifier         String?
  surname                String?
  dateOfBirth            String?
  birthCountryCode       String?
  monitorEnabled         Boolean            @default(true)
  monitorIntervalMinutes Int                @default(720)
  lastKnownStatus        String?
  lastCheckedAt          DateTime?
  nextCheckAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  snapshots              IrccCaseSnapshot[]

  @@index([ownerId, monitorEnabled, nextCheckAt])
  @@index([leadId])
}

model IrccCaseSnapshot {
  id            String          @id @default(cuid())
  caseProfileId String
  caseProfile   IrccCaseProfile @relation(fields: [caseProfileId], references: [id], onDelete: Cascade)
  status        String
  detailLines   String[]
  source        String          @default("manual")
  checkedAt     DateTime        @default(now())
  rawPayload    Json?

  @@index([caseProfileId, checkedAt])
}

model ConsultationHostProfile {
  id                     String                          @id @default(cuid())
  userId                 String                          @unique
  user                   User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingSlug            String                          @unique
  timezone               String                          @default("America/Toronto")
  defaultDurationMinutes Int                             @default(30)
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt

  availabilityWindows    ConsultationAvailabilityWindow[]
  blockedDates           ConsultationBlockedDate[]
  consultations          Consultation[]

  @@index([bookingSlug])
}

model ConsultationAvailabilityWindow {
  id            String                  @id @default(cuid())
  hostProfileId String
  hostProfile   ConsultationHostProfile @relation(fields: [hostProfileId], references: [id], onDelete: Cascade)
  dayOfWeek     Int
  startMinutes  Int
  endMinutes    Int
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@unique([hostProfileId, dayOfWeek])
  @@index([hostProfileId, dayOfWeek])
}

model ConsultationBlockedDate {
  id            String                  @id @default(cuid())
  hostProfileId String
  hostProfile   ConsultationHostProfile @relation(fields: [hostProfileId], references: [id], onDelete: Cascade)
  dateKey       String
  label         String?
  createdAt     DateTime                @default(now())

  @@unique([hostProfileId, dateKey])
  @@index([hostProfileId, dateKey])
}

model Consultation {
  id            String                  @id @default(cuid())
  hostId        String
  host          User                    @relation("ConsultationHost", fields: [hostId], references: [id], onDelete: Cascade)
  hostProfileId String
  hostProfile   ConsultationHostProfile @relation(fields: [hostProfileId], references: [id], onDelete: Cascade)
  attendeeName  String
  attendeeEmail String
  attendeePhone String?
  scheduledAt   DateTime
  endsAt        DateTime
  status        ConsultationStatus      @default(PENDING)
  completedAt   DateTime?
  meetingCode   String                  @unique
  meetingPath   String
  meetingUrl    String
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  meetingEvents ConsultationMeetingEvent[]

  @@index([hostId, scheduledAt])
  @@index([hostProfileId, scheduledAt])
  @@index([status, scheduledAt])
  @@index([meetingCode])
}

model ConsultationMeetingEvent {
  id             String                  @id @default(cuid())
  consultationId String
  consultation   Consultation            @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  senderRole     ConsultationMeetingRole
  senderClientId String
  targetRole     ConsultationMeetingRole?
  targetClientId String?
  eventType      String
  payload        Json?
  createdAt      DateTime                @default(now())

  @@index([consultationId, createdAt])
  @@index([consultationId, senderRole, createdAt])
  @@index([consultationId, targetRole, createdAt])
  @@index([consultationId, targetClientId, createdAt])
}
